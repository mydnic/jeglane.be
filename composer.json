{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "grkamil/laravel-telegram-logging": "^1.13",
        "inertiajs/inertia-laravel": "^v2.0.19",
        "laravel/framework": "^v12.50.0",
        "laravel/jetstream": "^v5.4.0",
        "laravel/sanctum": "^v4.3.0",
        "laravel/socialite": "^v5.24.2",
        "laravel/tinker": "^v2.11.0",
        "league/flysystem-aws-s3-v3": "^3.29",
        "mydnic/changelog-commit-for-laravel": "^v1.0.0",
        "mydnic/volet": "^v2.2.1",
        "mydnic/volet-feature-board": "^v1.1.0",
        "spatie/laravel-image-optimizer": "^1.8.2",
        "spatie/laravel-log-dumper": "^1.6.0",
        "tightenco/ziggy": "^v2.6.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel-lang/lang": "^15.7",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^v4.3.2",
        "pestphp/pest-plugin-laravel": "^v4.0.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
